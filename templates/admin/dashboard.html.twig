{% extends 'base.html.twig' %}

{% block title %}Admin Dashboard{% endblock %}

{% block body %}
<div style="margin-bottom: 30px;">
    <h2 style="font-size: 2em; color: #00497c; font-weight: 800;">⚙️ Tableau de bord Admin</h2>
    <p style="color: #6a7a8a;">Bienvenue dans l'interface d'administration</p>
</div>

<div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: 20px; margin-bottom: 30px;">
    <div style="background: linear-gradient(135deg, #00497c, #0074c7); color: white; padding: 25px; border-radius: 15px; text-align: center;">
        <div style="font-size: 2.5em;">👥</div>
        <div style="font-size: 2em; font-weight: 800;">{{ totalUsers }}</div>
        <div style="color: rgba(255,255,255,0.8);">Utilisateurs</div>
    </div>
    <div style="background: linear-gradient(135deg, #82b864, #6a9e50); color: white; padding: 25px; border-radius: 15px; text-align: center;">
        <div style="font-size: 2.5em;">📚</div>
        <div style="font-size: 2em; font-weight: 800;">{{ totalCourses }}</div>
        <div style="color: rgba(255,255,255,0.8);">Cursus</div>
    </div>
    <div style="background: linear-gradient(135deg, #f0ad4e, #e08e0b); color: white; padding: 25px; border-radius: 15px; text-align: center;">
        <div style="font-size: 2.5em;">🛒</div>
        <div style="font-size: 2em; font-weight: 800;">{{ totalPurchases }}</div>
        <div style="color: rgba(255,255,255,0.8);">Achats</div>
    </div>
</div>

<div style="background: white; padding: 25px; border-radius: 15px; box-shadow: 0 4px 20px rgba(0,0,0,0.06);">
    <h3 style="color: #00497c; margin-bottom: 15px;">📋 Derniers utilisateurs</h3>
    <table style="width: 100%; border-collapse: collapse;">
        <thead>
            <tr style="background: #f1f8fc; border-bottom: 2px solid #e8edf2;">
                <th style="padding: 12px; text-align: left;">Email</th>
                <th style="padding: 12px; text-align: left;">Rôle</th>
                <th style="padding: 12px; text-align: left;">Activé</th>
                <th style="padding: 12px; text-align: left;">Date</th>
            </tr>
        </thead>
        <tbody>
            {% for user in recentUsers %}
                <tr style="border-bottom: 1px solid #e8edf2;">
                    <td style="padding: 12px;">{{ user.email }}</td>
                    <td style="padding: 12px;">
                        <span style="background: {% if 'ROLE_ADMIN' in user.roles %} #cd2c2e {% else %} #82b864 {% endif %}; color: white; padding: 3px 12px; border-radius: 20px; font-size: 0.8em;">
                            {{ user.roles|join(', ') }}
                        </span>
                    </td>
                    <td style="padding: 12px;">{% if user.isActive %}✅{% else %}❌{% endif %}</td>
                    <td style="padding: 12px;">{{ user.createdAt|date('d/m/Y H:i') }}</td>
                </tr>
            {% endfor %}
        </tbody>
    </table>
    <div style="margin-top: 20px;">
        <a href="{{ path('app_admin_users') }}" class="btn btn-primary">Voir tous les utilisateurs →</a>
    </div>
</div>
{% endblock %}